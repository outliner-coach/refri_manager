# Common
NODE_ENV=development
APP_TIMEZONE=Asia/Seoul
MONTHLY_BUDGET_KRW=50000

# API / Worker
PORT=4000
DATABASE_URL=mysql://root:root@localhost:3306/refri_manager
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIPTION_LANGUAGE=ko
# Optional override. Leave blank to use the built-in Korean transcription prompt.
OPENAI_TRANSCRIPTION_PROMPT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
ADMIN_ALERT_CHANNEL=#fridge-admin

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_MEMBERS_RANGE=members!A:D
GOOGLE_SHEETS_ADMINS_RANGE=admin!A:A
GOOGLE_SERVICE_ACCOUNT_JSON=

# Object storage (MinIO/S3 compatible)
MINIO_ENDPOINT=http://localhost:9000
# Optional fixed browser endpoint for presigned URLs. Leave blank to auto-derive from API host.
MINIO_PUBLIC_ENDPOINT=
MINIO_PUBLIC_PORT=9100
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=refri-assets
MINIO_FORCE_PATH_STYLE=true
